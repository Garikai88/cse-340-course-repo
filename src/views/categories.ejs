<%- include('../partials/header') %>

<main class="container my-4" style="max-width: 800px; margin: 0 auto; padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #e9ecef; padding-bottom: 10px;">
        <h1><%= title %></h1>
        
        <a href="/edit-category/<%= category.category_id %>" class="btn btn-warning" style="text-decoration: none; padding: 8px 16px; background-color: #ffc107; color: #212529; border-radius: 4px; font-weight: bold;">
            ✏️ Edit Category Name
        </a>
    </div>

    <div class="card my-3" style="background: #ffffff; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px;">
        <h3 style="margin-top: 0;">Assigned Service Projects</h3>
        
        <% if (projects && projects.length > 0) { %>
            <ul style="padding-left: 20px; line-height: 1.8;">
                <% projects.forEach(project => { %>
                    <li>
                        <a href="/projects/<%= project.project_id %>" style="color: #0056b3; font-weight: 500; text-decoration: none;">
                            <%= project.title %>
                        </a>
                        <% if (project.location) { %>
                            <span style="color: #6c757d; font-size: 0.9rem;"> — (<%= project.location %>)</span>
                        <% } %>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p style="color: #6c757d; font-style: italic;">No service projects have been assigned to this category yet.</p>
        <% } %>
    </div>

    <div style="margin-top: 30px; border-top: 1px solid #dee2e6; padding-top: 15px;">
        <a href="/categories" style="color: #495057; text-decoration: none; font-weight: 500;">
            ⬅️ Back to All Categories
        </a>
    </div>
</main>

<%- include('../partials/footer') %>