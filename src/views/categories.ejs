<%- include('partials/header') %>

<main class="container my-4" style="max-width: 800px; margin: 0 auto; padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #e9ecef; padding-bottom: 10px;">
        <h1><%= title %></h1>
        
        <% if (user && user.role_name === 'admin') { %>
            <a href="/new-category" class="btn btn-primary" style="text-decoration: none; padding: 8px 16px; background-color: #007bff; color: #ffffff; border-radius: 4px; font-weight: bold;">
                ➕ Add New Category
            </a>
        <% } %>
    </div>

    <div class="categories-list" style="display: grid; gap: 15px;">
        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
            <% categories.forEach(function(category) { %>
                <div class="card" style="background: #ffffff; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <a href="/category/<%= category.category_id %>" style="font-size: 1.25rem; font-weight: bold; color: #0056b3; text-decoration: none;">
                            <%= category.name %>
                        </a>
                    </div>
                    
                    <% if (user && user.role_name === 'admin') { %>
                        <div>
                            <a href="/edit-category/<%= category.category_id %>" class="btn btn-warning" style="text-decoration: none; padding: 6px 12px; background-color: #ffc107; color: #212529; border-radius: 4px; font-size: 0.9rem; font-weight: bold;">
                                ✏️ Edit
                            </a>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <p style="color: #6c757d; font-style: italic;">No categories found.</p>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>