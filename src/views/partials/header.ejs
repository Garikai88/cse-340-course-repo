<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/organizations">Organizations</a>
        <a href="/projects">Projects</a>
        <a href="/categories">Categories</a>

        <% if (locals.user && user.role_name === 'admin') { %>
            <span class="admin-badge">| Admin:</span>
            <a href="/new-organization">Add Organization</a>
            <a href="/new-project">Add Projects</a>
            <a href="/new-category">Add Category</a>
            <a href="/users" style="font-weight: bold; color: #dc3545;">Manage Users</a> 
        <% } %>
        
        <% if (locals.isLoggedIn) { %>
            <a href="/dashboard">Dashboard</a>
            <a href="/logout">Logout</a>
        <% } else { %> 
            <a href="/login">Login</a>
            <a href="/register">Register</a>
        <% } %>    
    </nav>

    <% const messages = flash(); %>

<% Object.keys(messages).forEach(function(type) { %>
    <% if (messages[type] && messages[type].length > 0) { %>
        <div class="flash-messages">
            <% messages[type].forEach(function(msg) { %>
                <div class="alert alert-<%= type %>">
                    <%= msg %>
                </div>
            <% }); %>
        </div>
    <% } %>
<% }); %>