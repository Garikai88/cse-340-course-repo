<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

<% if (user && user.role_name === 'admin') { %>
    <div class="admin-actions">
        <a href="/new-organization" class="btn btn-add">➕ Add New Organization</a>
    </div>
<% } %>

        <div class="action-bar" style="margin-bottom: 20px;">
            <p><a href="/new-project" class="btn btn-success">Add a New Service Project</a></p>
        </div>

        <h2>Upcoming Service Projects</h2>
        <ul>
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach(project => { %>
                    <li>
                        <strong>
                            <% 
                                // Format the date to be user-friendly (e.g., "June 5, 2026")
                                const formattedDate = new Date(project.project_date).toLocaleDateString('en-US', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                    timeZone: 'UTC' // Prevents time zone shifts from changing the date 
                                });
                            %>
                            <%= formattedDate %>:
                        </strong>
                        
                        <a href="/project/<%= project.project_id %>"><%= project.project_title %></a>
                        
                        <em>(<%= project.organization_name %>)</em>
                    </li>
                <%}); %>
            <%} else { %>
                <li>No upcoming service projects found at this time.</li>
            <% } %>
        </ul>
    </main>
    <%- include('partials/footer') %>
    
</body>
</html>