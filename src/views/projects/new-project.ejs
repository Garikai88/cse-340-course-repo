<%- include('../partials/header') %>

<main class="form-container">
    <% if (user && user.role_name === 'admin') { %>

        <h1>Add New Service Project</h1>

        <% if (messages && messages.error) { %>
            <div class="flash-message error-messages">
                <% messages.error.forEach(function(msg) { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/new-project" method="POST" class="project-form">

            <div class="form-group">
                <label for="organizationId">Partner Organization *</label>
                <select name="organizationId" id="organizationId" required>
                    <option value="" selected disabled>Select an Organization....</option>
                    
                    <% organizations.forEach(function(org) { %>
                        <option value="<%= org.organization_id %>">
                            <%= org.name %>
                        </option>
                    <% }); %>
                </select>        
            </div>

            <div class="form-group">
                <label for="title">Project Title *</label>
                <input type="text" name="title" id="title" required>
            </div>

            <div class="form-group">
                <label for="location">Location *</label>
                <input type="text" name="location" id="location" required>
            </div>

            <div class="form-group">
                <label for="date">Project Date *</label>
                <input type="date" name="date" id="date" required>
            </div>

             <div class="form-group">
                <label for="description">Project Description *</label>
                <textarea name="description" id="description" rows="5" required></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Add Project</button>
                <a href="/projects" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    <% } else { %>
        <div class="unauthorized-box" style="text-align: center; padding: 40px 20px;">
            <h2>Access Denied</h2>
            <p style="color: #6c757d;">You do not have the necessary administrative privileges to create a new service project.</p>
            <a href="/" class="btn btn-primary" style="text-decoration: none;">Return Home</a>
        </div>
    <% } %>

</main>

<%- include('../partials/footer') %>