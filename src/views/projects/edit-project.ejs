<%- include('../partials/header') %>
    <main class="form-container">
        <h1>Edit Service Project</h1>

        <% if (messages && messages.error) { %>
            <div class="flash-message error-messages">
                <% messages.error.forEach(function(msg) { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/edit-project/<%= projectDetails.project_id %>" method="POST" class="project-form">

            <div class="form-group">
                <label for="organizationId">Partner Organization *</label>
                <select name="organizationId" id="organizationId" required>
                    <option value="" disabled>Select an Organization....</option>
                    
                    <% organizations.forEach(function(org) { %>
                        <option value="<%= org.organization_id %>" <%= org.organization_id === projectDetails.organization_id ? 'selected' : '' %>>
                            <%= org.name %>
                        </option>
                    <% }); %>
                </select>        
            </div>

            <div class="form-group">
                <label for="title">Project Title *</label>
                <input type="text" name="title" id="title" value="<%= projectDetails.title %>" required>
            </div>

            <div class="form-group">
                <label for="location">Location *</label>
                <input type="text" name="location" id="location" value="<%= projectDetails.location %>" required>
            </div>

            <div class="form-group">
                <label for="date">Project Date *</label>
                <% 
                    let formattedDate = '';
                    if (projectDetails.project_date) {
                        const d = new Date(projectDetails.project_date);
                        formattedDate = d.toISOString().split('T')[0];
                    }
                %>
                <input type="date" name="date" id="date" value="<%= formattedDate %>" required>
            </div>

             <div class="form-group">
                <label for="description">Project Description *</label>
                <textarea name="description" id="description" rows="5" required><%= projectDetails.description %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/projects/<%= projectDetails.project_id %>" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    </main>
<%- include('../partials/footer') %>