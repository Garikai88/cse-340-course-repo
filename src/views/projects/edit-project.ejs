<label%- include('partials/header') %>
<main class="container">

    <h1><%= title %></h1>

    <form action="/edit-project/<%= projectDetails.project_id %>" method="POST" class="card p-4 shadow-sm">
        <!-- Form fields for editing project details -->

        <div class="from-group">
            <label for="title" class="form-label">Project Title</label>
            <input type="text" id="title" name="title" class="form-control" value="<%= projectDetails.title %>" required />
        </div>

        <div class="form-group">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="description" class="form-control" rows="4" required><%= projectDetails.description %></textarea>
        </div>

        <div class="form-group">
            <label for="location" class="form-label">Location</label>
            <input type="text" id="location" name="location" class="form-control" value="<%= projectDetails.location %>" required />
        </div>

        <div class="form-group">
            <label for="date" class="form-label">Project Date</label>
            <%
                let formattedDate = '';
                if (projectDetails.project_date) {
                    let d = new Date(projectDetails.project_date);
                    formattedDate = d.toISOString().split('T')[0];
                }
            %>
            <input type="date" id="date" name="date" class="form-control" value="<%= formattedDate %>" required />
        </div>

        <div class="form-group">
            <label for="organizationId" class="from-label">Partner Organization Owner</label>
            <select id="organizationId" name="organizationId" class="form-select" required>
                <option value="">-- Choose Organization --</option>
                <option% organization.forEach(org => { %>
                    <option value="<%= org.organization_id %>"
                        <%= org.organization_id === projectDetails.organization_id ? 'selected' : ''%>
                    >
                        <%= org.name %>

                    </option>
                <% }) %>
            </select>
        </div>

        <div class="d-flex justify-content-between">
            <a href="/projects/<%= projectDetails.project_id %>" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Update Project</button>
        </div>
    </form>
</main>
<%- include('partials/footer') %>