<%- include('partials/header') %>
<main class="detail-container">
    <h1><%= title %></h1>

    <h2><%= organizationDetails.name %></h2>
    
    <div class="logo-wrapper">
        <img src="/images/<%= organizationDetails.logo_filename || 'placeholder-logo.png' %>" alt="<%= organizationDetails.name %> logo">
    </div>

    <p class="action-buttons">
        <a href="/edit-organization/<%= organizationDetails.organization_id %>" class="btn btn-warning">
            Edit Organization Details
        </a>
    </p>

    <p><strong>Description:</strong> <%= organizationDetails.description %></p>
    
    <p><strong>Contact Email:</strong> <%= organizationDetails.contact_email %></p>

    <h3>Service Projects</h3>
    <ul class="project-list">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/projects/<%= project.project_id || project.id %>">
                        <%= project.title || project.name %>
                    </a>
                </li>
            <% }) %>
        <% } else { %>
            <li class="no-data">No service projects found for this organization.</li>
        <% } %>
    </ul>
</main>
<%- include('partials/footer') %>