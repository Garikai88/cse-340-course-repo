<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Welcome to the CSE 340 Service Network!</h2>
        <p>Our mission is to promote services across the world by connecting volunteers with service opportunities in their community.</p>

        <img class="main-logo" src="/images/cse340-service-network.png" alt="cse 340 service Network Logo">
    </main>
    <% if (isLoggedIn) { %>
        <p><a href="/dashboard">My Dashboard</a></p>
    <% } %>
    <%- include('partials/footer') %>
    
</body>
</html>